# Copy this to .env and fill in your values

# Story Generation
GROQ_API_KEY=your_groq_api_key_here
USE_FREE_MODE=false

# Image Generation
IMAGE_MODE=infip
INFIP_API_KEY=your_infip_api_key_here
HUGGINGFACE_API_KEY=your_hf_key_here

# Database (leave empty for SQLite locally, set for PostgreSQL on Railway)
DATABASE_URL=

# Production
PORT=8025
